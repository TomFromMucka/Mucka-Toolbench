# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.

# Required: your ElevenLabs account API key (Settings → API Keys).
ELEVENLABS_API_KEY=

# Required on first `npm run mucka:sync`: the voice ID for Mucka.
# Same voice you use in Mucka Pro. Open the voice in Voice Library and
# copy the ID from the URL or its settings.
ELEVENLABS_MUCKA_VOICE_ID=

# Set after first `npm run mucka:sync` — the script creates a new agent
# and prints this ID for you to paste in here.
MUCKA_AGENT_ID=

# Text-mode Mucka runs on the Claude Agent SDK, which uses your existing
# Claude Code CLI auth (Pro/Max subscription via `claude login`). No API
# key needed. Run `claude logout` then `claude login` to re-auth.
#
# Optional override — pin a specific model for text mode. Defaults to
# the CLI default.
# MUCKA_TEXT_MODEL=claude-sonnet-4-6

# Vercel API token — generate at https://vercel.com/account/tokens
# Used by the Vercel panel and the deploy_to_vercel Mucka tool. Without
# this the panel shows a "token missing" banner.
VERCEL_API_TOKEN=

# Optional. Only needed if your projects belong to a Vercel team AND the
# team id is not already recorded in each worktree's .vercel/project.json.
# Most users can leave this blank.
VERCEL_TEAM_ID=

# GitHub personal access token — used by the Git panel and the open_pr
# Mucka tool. Fine-grained PAT with read access to your repos is enough
# for the panel (pulls + check-runs). Generate at:
#   https://github.com/settings/tokens?type=beta
# `GH_TOKEN` is also accepted (same env name the gh CLI uses).
GITHUB_TOKEN=
