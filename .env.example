# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.

# Required: your ElevenLabs account API key (Settings → API Keys).
ELEVENLABS_API_KEY=

# Required on first `npm run mucka:sync`: the voice ID for Mucka.
# Same voice you use in Mucka Pro. Open the voice in Voice Library and
# copy the ID from the URL or its settings.
ELEVENLABS_MUCKA_VOICE_ID=

# Set after first `npm run mucka:sync` — the script creates a new agent
# and prints this ID for you to paste in here.
MUCKA_AGENT_ID=
